{
    "$schema": "./conf/zowe/zowe.schema.json",
    "myNotes": [
        "- Zowe does not honor local .ssh/config. So you'll need to repeat them here.",
        "- For `connection refused` error, check that the Service(STC/Daemon) is active on and on the right port and firewall define on host vm.",
        "- For `Rest API failure with HTTP(S) status 404` check zOSMF props. In one case I fix it by removing the baseapi key from the project_base. It must be a default?",
        "- For 'Received HTTP(S) error 403 = Forbidden.'  JMON not started",
        "- Sometimes Zowe`s cache can create issues like adding credentials when switching zOS hosts. In that case, restart vs code.",
        "- RCE uses the zos dns name like std1.ibm.com  so i added that to /etc/hosts as an rse host.",
        "- If the cics profile errors out, run (f1) `zowe explorer: update profile ...",
        "- Step 4 (check zOS profiles) taking very long for rseapi on taz box???  ..."
    ],
    "profiles": {
        "poc-waas-zosmf": {
            "type": "zosmf",
            "properties": {
                "host": "poc-waas",
                "port": 10443
            }
        },
        "poc-waas-rse": {
            "type": "rse",
            "properties": {
                "host": "poc-waas",
                "port": 8195,
                "basePath": "rseapi",
                "protocol": "https",
                "rejectUnauthorized": false
            }
        },
        "zOpenDebug": {
            "type": "zOpenDebug",
            "properties": {
                "host": "taz-zos",
                "COMMENT1": "DPS (Profile service) port connect to the EQAPROF STC",
                "dpsPort": 8192,
                "dpsContextRoot": "api/v1",
                "dpsSecured": true,
                "COMMENT2": "RDS (Remote Client service) port connect to the EQARMTD STC. SECURED",
                "rdsPort": 8194,
                "rdsSecured": true,
                "COMMENT3": "Basic racf userid/password login credentials",
                "authenticationType": "basic",
                "uuid": "e91d29b6-959f-4e17-b23d-4394fc8c0a7b"
            },
            "secure": [
                "user",
                "password"
            ]
        },
        "taz-zos-rse": {
            "type": "rse",
            "properties": {
                "port": 8195,
                "basePath": "rseapi",
                "protocol": "https",
                "host2": "STD1.ibm.com",
                "host": "taz-zos",
                "rejectUnauthorized": false
            },
            "secure": [
                "user",
                "password"
            ]
        },
        "taz-zos-tso": {
            "type": "tso",
            "properties": {
                "host": "taz-zos",
                "port": 992,
                "account": "ACCT001",
                "base-path": "/zowe/api",
                "privateKey": "C:/Users/NelsonLopez1/.ssh/odt4-std1/taz-key"
            }
        },
        "taz-zos-ssh": {
            "type": "ssh",
            "properties": {
                "host": "taz-zos",
                "port": 2022,
                "privateKey": "C:/Users/NelsonLopez1/.ssh/odt4-std1/taz-key"
            },
            "secure": [
                "user"
            ]
        },
        "taz-zos-zosmf": {
            "type": "zosmf",
            "properties": {
                "host": "taz-zos",
                "port": 10443
            },
            "secure": [
                "user",
                "password"
            ]
        },
        "taz-zos-cics": {
            "type": "cics",
            "properties": {
                "host": "taz-zos",
                "port": 8154
            },
            "secure": [
                "user",
                "password"
            ]
        },
        "project_base": {
            "type": "base",
            "properties": {
                "COMMENT0": "In the real world dont add any personal vars in the team zowe config. This is for demo only.",
                "host": "taz-zos",
                "privateKey": "C:/Users/NelsonLopez1/.ssh/odt4-std1/taz-key",
                "protocol": "https",
                "rejectUnauthorized": false
            },
            "secure": [
                "user",
                "password"
            ]
        }
    },
    "autoStore": true,
    "defaults": {
        "zosmf": "taz-zos-zosmf",
        "ssh": "taz-zos-ssh",
        "rse": "taz-zos-rse",
        "tso": "taz-zos-tso",
        "base": "project_base"
    }
}